"""
Quick test script to verify Streamlit app setup
This script checks that all required components are in place
"""

import sys
from pathlib import Path
import importlib.util

# Colors for terminal output
class Colors:
    GREEN = '\033[92m'
    RED = '\033[91m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    END = '\033[0m'

def check_file_exists(file_path: Path, description: str) -> bool:
    """Check if a file exists and print result."""
    exists = file_path.exists()
    status = f"{Colors.GREEN}[OK]{Colors.END}" if exists else f"{Colors.RED}[FAIL]{Colors.END}"
    size = f"({file_path.stat().st_size / 1024:.1f} KB)" if exists else ""
    print(f"{status} {description}: {file_path.name} {size}")
    return exists

def check_import(module_path: str, description: str) -> bool:
    """Check if a module can be imported."""
    try:
        importlib.import_module(module_path)
        print(f"{Colors.GREEN}[OK]{Colors.END} {description}: {module_path}")
        return True
    except ImportError as e:
        print(f"{Colors.RED}[FAIL]{Colors.END} {description}: {module_path} - {e}")
        return False

def main():
    """Run all checks."""
    print(f"\n{Colors.BLUE}{'='*60}{Colors.END}")
    print(f"{Colors.BLUE}Streamlit App Configuration Test{Colors.END}")
    print(f"{Colors.BLUE}{'='*60}{Colors.END}\n")

    project_root = Path(__file__).parent
    all_passed = True

    # Check file structure
    print(f"{Colors.YELLOW}Checking File Structure...{Colors.END}")
    files_to_check = [
        (project_root / "app" / "main.py", "Main entry point"),
        (project_root / "app" / "pages" / "1_Home.py", "Home dashboard page"),
        (project_root / "assets" / "styles" / "custom.css", "Custom CSS"),
        (project_root / "data" / "raw" / "data_globant_cleaned.csv", "Sample dataset"),
        (project_root / "src" / "data" / "loader.py", "Data loader module"),
        (project_root / "src" / "models" / "markov_model.py", "Markov model"),
        (project_root / "src" / "visualization" / "streamlit_components.py", "Streamlit components"),
    ]

    for file_path, desc in files_to_check:
        if not check_file_exists(file_path, desc):
            all_passed = False

    print()

    # Check Python packages
    print(f"{Colors.YELLOW}Checking Required Packages...{Colors.END}")
    packages = [
        ("streamlit", "Streamlit framework"),
        ("pandas", "Pandas data manipulation"),
        ("numpy", "NumPy numerical computing"),
        ("plotly", "Plotly interactive charts"),
    ]

    for package, desc in packages:
        if not check_import(package, desc):
            all_passed = False

    print()

    # Check project modules
    print(f"{Colors.YELLOW}Checking Project Modules...{Colors.END}")
    sys.path.insert(0, str(project_root))

    modules = [
        ("src.data.loader", "Data loader"),
        ("src.models.markov_model", "Markov model"),
        ("src.visualization.streamlit_components", "Streamlit components"),
    ]

    for module, desc in modules:
        if not check_import(module, desc):
            all_passed = False

    print()

    # Summary
    print(f"{Colors.BLUE}{'='*60}{Colors.END}")
    if all_passed:
        print(f"{Colors.GREEN}[OK] All checks passed! App is ready to run.{Colors.END}")
        print(f"\nTo start the app, run:")
        print(f"{Colors.BLUE}  streamlit run app/main.py{Colors.END}")
    else:
        print(f"{Colors.RED}[FAIL] Some checks failed. Please review the errors above.{Colors.END}")
    print(f"{Colors.BLUE}{'='*60}{Colors.END}\n")

    # Additional info
    print(f"{Colors.YELLOW}Quick Tips:{Colors.END}")
    print(f"  • Run from project root directory")
    print(f"  • Use Python 3.9+ for best compatibility")
    print(f"  • Install missing packages: pip install -r requirements.txt")
    print(f"  • Default URL: http://localhost:8501")
    print()

if __name__ == "__main__":
    main()
